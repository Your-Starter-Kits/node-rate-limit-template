# Server Configuration
PORT=3000
NODE_ENV=development

# Rate Limiting Configuration
# Maximum requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100
# Time window in minutes
RATE_LIMIT_WINDOW_MINUTES=15

# Slow Down Configuration (Speed throttling before blocking)
# Start slowing down after this many requests
SLOWDOWN_DELAY_AFTER=50
# Delay increment per request (in milliseconds)
SLOWDOWN_DELAY_MS=500

# API Configuration
API_PREFIX=/api/v1

# CORS Configuration
CORS_ORIGIN=*
